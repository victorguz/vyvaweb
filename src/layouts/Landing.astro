---
import '../styles/landing.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
}

const {
	title = 'Vyva | Agendamiento y gestión para servicios de belleza y bienestar',
	description = 'Vyva es el sistema todo-en-uno de agendamiento y gestión para salones, estéticas, spas y barberías. Reservas online 24/7, Google Calendar, clientes, punto de venta y reportes.',
	image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="robots" content="index, follow" />
		<meta name="author" content="Vyva" />
		<link rel="canonical" href={canonical} />
		<link rel="icon" href="/brand/Vyva_favicon.svg" type="image/svg+xml" />
		<meta name="theme-color" content="#7b8be9" />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Vyva" />
		<meta property="og:locale" content="es_CO" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		{ogImage && <meta property="og:image" content={ogImage} />}

		<meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{ogImage && <meta name="twitter:image" content={ogImage} />}

		<script is:inline>
			// Marca que JS está disponible para activar las animaciones de reveal
			// sin ocultar el contenido cuando JS está deshabilitado (SEO friendly).
			document.documentElement.classList.add('js');
		</script>
	</head>
	<body class="bg-white text-ink antialiased">
		<slot />

		<script>
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			const els = Array.from(
				document.querySelectorAll<HTMLElement>('[data-reveal]')
			);
			const revealAll = () =>
				els.forEach((el) => {
					el.style.opacity = '1';
					el.style.transform = 'none';
				});

			try {
				const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
				if (reduce || els.length === 0) {
					revealAll();
				} else {
					gsap.registerPlugin(ScrollTrigger);
					ScrollTrigger.batch(els, {
						start: 'top 90%',
						once: true,
						onEnter: (batch) =>
							gsap.to(batch, {
								opacity: 1,
								y: 0,
								duration: 0.6,
								ease: 'power3.out',
								stagger: 0.08,
								overwrite: true,
							}),
					});
					// Red de seguridad: si algo quedó oculto, muéstralo.
					window.setTimeout(() => {
						els.forEach((el) => {
							if (getComputedStyle(el).opacity === '0') {
								el.style.opacity = '1';
								el.style.transform = 'none';
							}
						});
					}, 2000);
				}
			} catch {
				revealAll();
			}
		</script>
	</body>
</html>
