---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import FeatureCard from '../components/marketing/FeatureCard.astro';
import Callout from '../components/marketing/Callout.astro';

const SIGNUP = 'https://app.vyvapos.com/plans/essential';
const SALES = 'https://calendly.com/victorguzber/conoce-vyva-pos';

const featureSections = [
	{
		title: 'Agendamiento y citas',
		items: [
			{ icon: 'add-document', title: 'Página de reservas', body: 'Link único con tu marca para que tus clientes reserven 24/7.' },
			{ icon: 'clock', title: 'Google Calendar', body: 'Sincronización automática de todas tus citas.' },
			{ icon: 'notes', title: 'Horarios flexibles', body: 'Disponibilidad por día, empleado y servicio.' },
			{ icon: 'bell-ringing', title: 'Recordatorios', body: 'Avisos por email para reducir ausencias.' },
			{ icon: 'users-three', title: 'Asignación de equipo', body: 'Citas según especialidad y disponibilidad.' },
			{ icon: 'list-format', title: 'Vista calendario', body: 'Timeline interactivo de todas tus citas.' },
		],
	},
	{
		title: 'Gestión de clientes',
		items: [
			{ icon: 'users', title: 'Base de datos', body: 'Contacto, preferencias y notas de cada cliente.' },
			{ icon: 'clock', title: 'Historial de citas', body: 'Servicios tomados y última visita.' },
			{ icon: 'approve-check', title: 'Historial de compras', body: 'Valor del cliente y productos preferidos.' },
			{ icon: 'chart-line', title: 'Estadísticas', body: 'Clientes nuevos, recurrentes y ticket promedio.' },
		],
	},
	{
		title: 'Punto de venta',
		items: [
			{ icon: 'storefront', title: 'Pagos', body: 'Cobra servicios y productos de forma segura.' },
			{ icon: 'add-document', title: 'Carrito integrado', body: 'Combina tratamientos y productos en una venta.' },
			{ icon: 'document', title: 'Facturación', body: 'Órdenes de venta y facturación centralizada.' },
			{ icon: 'setting', title: 'Múltiples métodos', body: 'Tarjetas, transferencias y más.' },
		],
	},
	{
		title: 'Dashboard y reportes',
		items: [
			{ icon: 'chart-line', title: 'KPIs en tiempo real', body: 'Ventas del día, clientes nuevos y ticket promedio.' },
			{ icon: 'list-format', title: 'Reportes de ventas', body: 'Por día, semana, mes o rango personalizado.' },
			{ icon: 'sparkle', title: 'Por método de pago', body: 'Ingresos desglosados por canal.' },
			{ icon: 'open-book', title: 'Gráficos', body: 'Visualizaciones para entender tu negocio de un vistazo.' },
		],
	},
	{
		title: 'Gestión de equipo',
		items: [
			{ icon: 'identification-card', title: 'Perfiles', body: 'Fotos, especialidades y horarios por empleado.' },
			{ icon: 'clock', title: 'Asignación', body: 'Distribución equitativa de citas.' },
			{ icon: 'lock-key', title: 'Roles y permisos', body: 'Control de acceso según el rol.' },
			{ icon: 'chart-line', title: 'Desempeño', body: 'Citas atendidas y ventas por miembro del equipo.' },
		],
	},
];

const useCases = [
	{ icon: 'sparkle', title: 'Salones de belleza', body: 'Cortes, tintes y peinados con estilistas por especialidad.' },
	{ icon: 'users', title: 'Estéticas faciales', body: 'Tratamientos, historial de clientes y venta de productos.' },
	{ icon: 'heart', title: 'Spas y bienestar', body: 'Múltiples salas, terapeutas y tratamientos coordinados.' },
	{ icon: 'document', title: 'Clínicas estéticas', body: 'Consultas, procedimientos y seguimiento.' },
	{ icon: 'approve-check', title: 'Barberías', body: 'Turnos, clientes recurrentes y servicios de barba.' },
	{ icon: 'heart', title: 'Centros de masajes', body: 'Tipos de masaje y terapeutas en una sola agenda.' },
];

const pricingFaqs = [
	{
		q: '¿Cómo funcionan los precios?',
		a: 'El equipo de Vyva define un precio simple y personalizado según el tipo de servicios y el tamaño de tu negocio, con acceso a todas las herramientas de la plataforma.',
	},
	{
		q: '¿Por qué contactar a ventas?',
		a: 'Para entender las necesidades de tu negocio, personalizar un plan, obtener el mejor precio y resolver dudas antes de decidir.',
	},
	{
		q: '¿Puedo probar antes de comprometerme?',
		a: 'Sí: prueba gratuita de 1 año completo sin compromiso.',
	},
];
---

<Landing
	title="Planes y precios | Vyva"
	description="Planes personalizados de Vyva para tu salón, estética o spa. Agendamiento, clientes, punto de venta y reportes en una sola plataforma."
>
	<Nav client:load />

	<main>
		<section class="page-hero relative overflow-hidden bg-white">
			<div
				class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(50%_50%_at_50%_0%,var(--color-brand-100),transparent_70%)]"
			>
			</div>
			<div class="mx-auto max-w-3xl px-5 text-center sm:px-8">
				<h1 data-reveal class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl">
					Planes y precios
				</h1>
				<p data-reveal class="mt-5 text-lg leading-relaxed text-slate-600">
					Planes simples y personalizados: citas, clientes, ventas y equipo en una sola plataforma.
				</p>
				<div data-reveal class="mt-8">
					<Callout variant="tip" title="Prueba gratuita de 1 año">
						Explora todas las funcionalidades antes de decidir. Sin compromiso.
					</Callout>
				</div>
				<div data-reveal class="mt-6 flex flex-col justify-center gap-3 sm:flex-row">
					<a
						href={SIGNUP}
						class="btn-press inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/25"
					>
						Probar gratis
						<Icon name="arrow-right" size={18} />
					</a>
					<a
						href={SALES}
						class="btn-press inline-flex items-center justify-center rounded-xl border border-slate-300 px-6 py-3.5 text-base font-semibold text-slate-700"
					>
						Contactar ventas
					</a>
				</div>
			</div>
		</section>

		{
			featureSections.map((section) => (
				<section class="border-t border-slate-100 bg-slate-50/50 py-16 sm:py-20">
					<div class="mx-auto max-w-7xl px-5 sm:px-8">
						<h2 data-reveal class="section-heading">
							{section.title}
						</h2>
						<div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
							{section.items.map((item) => (
								<div data-reveal>
									<FeatureCard icon={item.icon} title={item.title} body={item.body} />
								</div>
							))}
						</div>
					</div>
				</section>
			))
		}

		<section class="py-16 sm:py-20">
			<div class="mx-auto max-w-7xl px-5 sm:px-8">
				<h2 data-reveal class="section-heading text-center">Diseñado para tu tipo de negocio</h2>
				<p data-reveal class="mx-auto mt-3 max-w-2xl text-center text-slate-600">
					Vyva se adapta a salones, estéticas, spas, barberías y más.
				</p>
				<div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
					{
						useCases.map((item) => (
							<div data-reveal>
								<FeatureCard icon={item.icon} title={item.title} body={item.body} />
							</div>
						))
					}
				</div>
			</div>
		</section>

		<section class="border-t border-slate-100 bg-white py-16 sm:py-20">
			<div class="mx-auto max-w-3xl px-5 sm:px-8">
				<h2 data-reveal class="section-heading">Preguntas sobre precios</h2>
				<div class="mt-8 space-y-6">
					{
						pricingFaqs.map((faq) => (
							<div data-reveal class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
								<h3 class="font-semibold text-ink">{faq.q}</h3>
								<p class="mt-2 text-sm leading-relaxed text-slate-600">{faq.a}</p>
							</div>
						))
					}
				</div>
				<div data-reveal class="mt-8">
					<Callout variant="note" title="Sin costos ocultos">
						El precio acordado incluye las funcionalidades de la plataforma. Sin tarifas de
						configuración ni cancelación.
					</Callout>
				</div>
			</div>
		</section>

		<section class="px-5 pb-24 sm:px-8">
			<div
				class="relative mx-auto max-w-7xl overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 px-6 py-16 text-center sm:px-12"
			>
				<h2 data-reveal class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white">
					¿Listo para transformar tu negocio?
				</h2>
				<p data-reveal class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
					Prueba gratis o contacta a nuestro equipo para un plan personalizado.
				</p>
				<div data-reveal class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
					<a
						href={SIGNUP}
						class="btn-press inline-flex items-center justify-center gap-2 rounded-xl bg-white px-7 py-3.5 font-semibold text-brand-700"
					>
						Probar gratis
						<Icon name="arrow-right" size={18} />
					</a>
					<a
						href={SALES}
						class="btn-press inline-flex items-center justify-center rounded-xl border border-white/40 px-7 py-3.5 font-semibold text-white hover:bg-white/10"
					>
						Contactar ventas
					</a>
				</div>
				<p data-reveal class="mt-6 text-sm text-brand-200">
					Prueba gratuita de 1 año · Sin compromisos · Soporte personalizado
				</p>
			</div>
		</section>
	</main>

	<Footer />
</Landing>
