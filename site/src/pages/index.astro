---
import Landing from '../layouts/Landing.astro';
import Nav from '../components/Nav.svelte';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

const SIGNUP = 'https://app.vyvapos.com/plans/essential';

const benefits = [
	'Agenda online 24/7',
	'Google Calendar',
	'Gestión de clientes',
	'Punto de venta',
	'Reportes en tiempo real',
];

const pillars = [
	{
		icon: 'calendar-dots',
		title: 'Agendamiento online',
		body: 'Tus clientes reservan 24/7 desde una página con tu marca. Tú mantienes el control total de la agenda.',
	},
	{
		icon: 'users',
		title: 'Gestión de clientes',
		body: 'Base de datos con historial de citas y compras para fidelizar y dar un servicio personalizado.',
	},
	{
		icon: 'storefront',
		title: 'Punto de venta',
		body: 'Cobra servicios y productos en segundos. Carrito, facturación y control de caja integrados.',
	},
	{
		icon: 'users-three',
		title: 'Gestión de equipo',
		body: 'Asigna citas, define roles y permisos y haz seguimiento del desempeño de cada especialista.',
	},
	{
		icon: 'chart-line',
		title: 'Reportes en tiempo real',
		body: 'Ingresos, clientes nuevos y recurrentes y métricas clave para tomar mejores decisiones.',
	},
	{
		icon: 'arrows-clockwise',
		title: 'Google Calendar',
		body: 'Sincronización automática: cada cita de Vyva aparece al instante en tu Google Calendar.',
	},
];

const agendaFeatures = [
	{ icon: 'identification-card', title: 'Página de reservas personalizada', body: 'Comparte tu link único con tu marca y tus servicios.' },
	{ icon: 'bell-ringing', title: 'Recordatorios automáticos', body: 'Reduce las ausencias con avisos por email antes de cada cita.' },
	{ icon: 'clock', title: 'Horarios flexibles', body: 'Configura disponibilidad por día, empleado y servicio.' },
	{ icon: 'device-mobile', title: '100% responsive', body: 'Tus clientes reservan desde móvil, tablet o computador.' },
];

const useCases = [
	'Salones de belleza',
	'Estéticas y spas',
	'Barberías',
	'Clínicas estéticas',
	'Centros de bienestar',
	'Uñas y pestañas',
	'Peluquerías',
	'Masajes y terapias',
];
---

<Landing>
	<Nav client:load />

	<main>
		<!-- Hero -->
		<section class="relative overflow-hidden">
			<div
				class="pointer-events-none absolute inset-0 -z-10 bg-[radial-gradient(60%_60%_at_85%_10%,var(--color-brand-100),transparent_60%)]"
			>
			</div>
			<div
				class="mx-auto grid max-w-7xl items-center gap-12 px-5 pb-20 pt-16 sm:px-8 lg:grid-cols-2 lg:gap-8 lg:pb-28 lg:pt-24"
			>
				<div>
					<h1
						data-reveal
						class="text-4xl font-extrabold tracking-tight text-ink sm:text-5xl lg:text-6xl"
					>
						Agendamiento y gestión para tu
						<span class="text-brand-600">servicio de belleza</span> y bienestar
					</h1>
					<p data-reveal class="mt-6 max-w-xl text-lg leading-relaxed text-slate-600">
						Gestiona citas, clientes, ventas y equipo desde una sola plataforma
						todo-en-uno, hecha para salones, estéticas, spas y barberías.
					</p>
					<div data-reveal class="mt-8 flex flex-col gap-3 sm:flex-row">
						<a
							href={SIGNUP}
							class="btn-press inline-flex items-center justify-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/25"
						>
							Empezar gratis
							<Icon name="arrow-right" size={18} />
						</a>
						<a
							href="/pricing"
							class="btn-press inline-flex items-center justify-center rounded-xl border border-slate-300 px-6 py-3.5 text-base font-semibold text-slate-700 hover:border-slate-400"
						>
							Ver planes
						</a>
					</div>
				</div>

				<!-- Visual de marca (composición decorativa, no captura simulada) -->
				<div data-reveal class="relative">
					<div
						class="relative aspect-[4/3] overflow-hidden rounded-3xl bg-gradient-to-br from-brand-500 to-brand-700 p-6 shadow-2xl shadow-brand-700/30"
					>
						<div
							class="absolute inset-0 bg-[radial-gradient(40%_40%_at_20%_15%,rgba(255,255,255,0.25),transparent)]"
						>
						</div>

						<div class="absolute right-6 top-6 flex items-center gap-2 rounded-xl bg-white/95 px-4 py-3 shadow-lg">
							<span class="grid h-9 w-9 place-items-center rounded-lg bg-brand-100 text-brand-700">
								<Icon name="calendar-dots" size={20} />
							</span>
							<div>
								<p class="text-xs font-medium text-slate-500">Hoy</p>
								<p class="text-sm font-bold text-ink">12 citas</p>
							</div>
						</div>

						<div class="absolute left-6 top-1/2 w-60 -translate-y-4 rounded-xl bg-white/95 p-4 shadow-lg">
							<p class="text-xs font-medium text-slate-500">10:30 · Disponible</p>
							<p class="mt-1 text-sm font-bold text-ink">Corte + barba</p>
							<div class="mt-3 h-2 w-full rounded-full bg-slate-100">
								<div class="h-2 w-3/4 rounded-full bg-brand-500"></div>
							</div>
						</div>

						<div class="absolute bottom-6 right-6 flex items-center gap-2 rounded-xl bg-white/95 px-4 py-3 shadow-lg">
							<span class="grid h-9 w-9 place-items-center rounded-lg bg-emerald-100 text-emerald-700">
								<Icon name="chart-line" size={20} />
							</span>
							<div>
								<p class="text-xs font-medium text-slate-500">Ingresos</p>
								<p class="text-sm font-bold text-ink">+24% este mes</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Tira de beneficios -->
		<section class="border-y border-slate-200 bg-slate-50">
			<div
				class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-8 gap-y-3 px-5 py-5 sm:px-8"
			>
				{
					benefits.map((b) => (
						<span class="inline-flex items-center gap-2 text-sm font-medium text-slate-600">
							<Icon name="check" size={18} class="text-brand-600" />
							{b}
						</span>
					))
				}
			</div>
		</section>

		<!-- Características (pilares) -->
		<section id="caracteristicas" class="mx-auto max-w-7xl px-5 py-20 sm:px-8 lg:py-28">
			<div class="max-w-2xl">
				<p data-reveal class="text-sm font-semibold uppercase tracking-[0.18em] text-brand-600">
					Todo en una plataforma
				</p>
				<h2 data-reveal class="mt-3 text-3xl font-bold tracking-tight text-ink sm:text-4xl">
					Lo que necesitas para operar y hacer crecer tu negocio
				</h2>
			</div>

			<div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
				{
					pillars.map((p) => (
						<article
							data-reveal
							class="group rounded-2xl border border-slate-200 bg-white p-6 transition-colors duration-300 hover:border-brand-300"
						>
							<span class="grid h-12 w-12 place-items-center rounded-xl bg-brand-50 text-brand-700">
								<Icon name={p.icon as any} size={26} />
							</span>
							<h3 class="mt-5 text-lg font-bold text-ink">{p.title}</h3>
							<p class="mt-2 text-sm leading-relaxed text-slate-600">{p.body}</p>
						</article>
					))
				}
			</div>
		</section>

		<!-- Destacado: agenda inteligente -->
		<section class="bg-slate-50">
			<div class="mx-auto grid max-w-7xl items-center gap-12 px-5 py-20 sm:px-8 lg:grid-cols-2 lg:py-28">
				<div data-reveal>
					<h2 class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
						Tus clientes reservan, tú te enfocas en atenderlos
					</h2>
					<p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-600">
						Un sistema de agendamiento online completo que trabaja por ti las
						24 horas, sincronizado con tu calendario y tu equipo.
					</p>
					<a
						href={SIGNUP}
						class="btn-press mt-8 inline-flex items-center gap-2 rounded-xl bg-brand-600 px-6 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-600/25"
					>
						Empezar gratis
						<Icon name="arrow-right" size={18} />
					</a>
				</div>

				<div class="grid gap-4 sm:grid-cols-2">
					{
						agendaFeatures.map((f) => (
							<div data-reveal class="rounded-2xl border border-slate-200 bg-white p-5">
								<span class="grid h-10 w-10 place-items-center rounded-lg bg-brand-50 text-brand-700">
									<Icon name={f.icon as any} size={22} />
								</span>
								<h3 class="mt-4 font-semibold text-ink">{f.title}</h3>
								<p class="mt-1 text-sm leading-relaxed text-slate-600">{f.body}</p>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Casos de uso -->
		<section id="casos" class="mx-auto max-w-7xl px-5 py-20 sm:px-8 lg:py-28">
			<div class="max-w-2xl">
				<h2 data-reveal class="text-3xl font-bold tracking-tight text-ink sm:text-4xl">
					Hecho para los negocios de belleza y bienestar
				</h2>
				<p data-reveal class="mt-4 text-lg leading-relaxed text-slate-600">
					Si tu negocio vive de las citas y de la relación con tus clientes,
					Vyva se adapta a tu día a día.
				</p>
			</div>

			<div data-reveal class="mt-12 flex flex-wrap gap-3">
				{
					useCases.map((u) => (
						<span class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-4 py-2.5 text-sm font-medium text-slate-700">
							<Icon name="sparkle" size={16} class="text-brand-500" />
							{u}
						</span>
					))
				}
			</div>
		</section>

		<!-- CTA final -->
		<section class="px-5 pb-24 sm:px-8">
			<div
				class="relative mx-auto max-w-7xl overflow-hidden rounded-3xl bg-gradient-to-br from-brand-600 to-brand-800 px-6 py-16 text-center sm:px-12 lg:py-20"
			>
				<div
					class="pointer-events-none absolute inset-0 bg-[radial-gradient(40%_50%_at_50%_0%,rgba(255,255,255,0.18),transparent)]"
				>
				</div>
				<h2 data-reveal class="mx-auto max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl">
					Empieza gratis y haz crecer tu negocio con Vyva
				</h2>
				<p data-reveal class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
					Configura tus servicios, comparte tu página de reservas y recibe citas
					hoy mismo.
				</p>
				<div data-reveal class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
					<a
						href={SIGNUP}
						class="btn-press inline-flex items-center justify-center gap-2 rounded-xl bg-white px-7 py-3.5 text-base font-semibold text-brand-700 shadow-lg"
					>
						Empezar gratis
						<Icon name="arrow-right" size={18} />
					</a>
					<a
						href="/pricing"
						class="btn-press inline-flex items-center justify-center rounded-xl border border-white/40 px-7 py-3.5 text-base font-semibold text-white hover:bg-white/10"
					>
						Ver planes
					</a>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Landing>
