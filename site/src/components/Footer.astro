---
const year = new Date().getFullYear();
const links = [
	{ label: 'Planes', href: '/pricing' },
	{ label: 'Preguntas frecuentes', href: '/faq' },
	{ label: 'Documentación', href: '/intro' },
	{ label: 'Privacidad', href: '/privacy' },
	{ label: 'Términos', href: '/terms' },
];
---

<footer class="bg-ink text-slate-300">
	<div
		class="mx-auto flex max-w-7xl flex-col gap-8 px-5 py-12 sm:px-8 md:flex-row md:items-center md:justify-between"
	>
		<div class="flex flex-col gap-4">
			<a href="/" class="inline-flex">
				<img src="/brand/vyva_logo_white.svg" alt="Vyva" class="h-7 w-auto" />
			</a>
			<p class="max-w-xs text-sm text-slate-400">
				Agendamiento y gestión todo-en-uno para servicios de belleza y bienestar.
			</p>
		</div>

		<nav class="grid grid-cols-2 gap-x-10 gap-y-2 sm:grid-cols-3" aria-label="Pie de página">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="text-sm text-slate-400 transition-colors duration-200 hover:text-white"
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>

	<div class="border-t border-white/10">
		<div class="mx-auto max-w-7xl px-5 py-6 text-sm text-slate-500 sm:px-8">
			© {year} Vyva POS, LLC. Todos los derechos reservados.
		</div>
	</div>
</footer>
